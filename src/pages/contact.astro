---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Fale Conosco — Triaxis Consultoria',
  description: 'Entre em contato com a Triaxis. Atendemos em Ouro Preto, Mariana e Belo Horizonte - MG. Solicite um diagnóstico ou tire suas dúvidas.',
};
---

<Layout metadata={metadata}>

  <!-- HERO -->
  <section class="bg-[#1a3044] py-20 text-center px-4">
    <p class="text-sm text-[#6fcf7f] font-bold tracking-widest uppercase mb-3">Fale Conosco</p>
    <h1 class="text-3xl md:text-5xl font-black text-white leading-tight mb-5 max-w-3xl mx-auto">
      Vamos iniciar a transformação juntos
    </h1>
    <div class="w-20 h-1 bg-orange-500 mx-auto rounded-full mb-6"></div>
    <p class="text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
      Seja para um diagnóstico inicial, dúvidas sobre conformidade legal ou para otimizar os processos da sua empresa — nossa equipe está pronta para ajudar.
    </p>
  </section>

  <!-- CARDS DE CONTATO -->
  <section class="bg-slate-50 py-12 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 tx-fade">
      <a href="https://wa.me/5531994915126" target="_blank" rel="noopener noreferrer"
        class="contact-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col items-center text-center gap-3 group">
        <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center">
          <Icon name="tabler:brand-whatsapp" class="w-6 h-6 text-[#25d366]" />
        </div>
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">WhatsApp</p>
          <p class="text-sm font-bold text-[#1a3044] group-hover:text-[#3a8d44] transition-colors">(31) 99491-5126</p>
        </div>
      </a>

      <a href="mailto:daiannalana@triaxisdesenvolvimento.com.br"
        class="contact-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col items-center text-center gap-3 group">
        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center">
          <Icon name="tabler:mail" class="w-6 h-6 text-[#1a3044]" />
        </div>
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">E-mail</p>
          <p class="text-sm font-bold text-[#1a3044] group-hover:text-[#3a8d44] transition-colors break-all">daiannalana@triaxisdesenvolvimento.com.br</p>
        </div>
      </a>

      <div class="contact-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col items-center text-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center">
          <Icon name="tabler:map-pin" class="w-6 h-6 text-orange-500" />
        </div>
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Localização</p>
          <p class="text-sm font-bold text-[#1a3044]">Ouro Preto · Mariana</p>
          <p class="text-sm font-bold text-[#1a3044]">Belo Horizonte — MG</p>
        </div>
      </div>

      <div class="contact-card bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col items-center text-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
          <Icon name="tabler:clock" class="w-6 h-6 text-[#1a3044]" />
        </div>
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Atendimento</p>
          <p class="text-sm font-bold text-[#1a3044]">Segunda a Sexta</p>
          <p class="text-sm text-slate-500">8h às 18h</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULÁRIO + WHATSAPP -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

      <!-- FORMULÁRIO -->
      <div class="tx-fade">
        <p class="text-sm text-[#1a3044] font-bold tracking-widest uppercase mb-2">Envie uma mensagem</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[#1a3044] mb-2">Preencha o formulário</h2>
        <div class="w-16 h-1 bg-[#3a8d44] rounded-full mb-8"></div>

        <form
          action="https://formspree.io/f/mojyojeo"
          method="POST"
          class="space-y-5"
          id="contact-form"
        >
          <div>
            <label for="nome" class="block text-sm font-semibold text-slate-700 mb-1.5">Nome completo <span class="text-red-500">*</span></label>
            <input
              type="text"
              id="nome"
              name="nome"
              required
              placeholder="Seu nome"
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#3a8d44] focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">E-mail <span class="text-red-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="seuemail@empresa.com"
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#3a8d44] focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="telefone" class="block text-sm font-semibold text-slate-700 mb-1.5">Telefone / WhatsApp</label>
            <input
              type="tel"
              id="telefone"
              name="telefone"
              placeholder="(31) 99999-9999"
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#3a8d44] focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="servico" class="block text-sm font-semibold text-slate-700 mb-1.5">Área de interesse</label>
            <select
              id="servico"
              name="servico"
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#3a8d44] focus:border-transparent transition bg-white"
            >
              <option value="">Selecione uma área...</option>
              <option value="Engenharia Ambiental">Engenharia Ambiental</option>
              <option value="Engenharia de Produção">Engenharia de Produção</option>
              <option value="Saúde e Segurança do Trabalho">Saúde e Segurança do Trabalho</option>
              <option value="Outro">Outro</option>
            </select>
          </div>

          <div>
            <label for="mensagem" class="block text-sm font-semibold text-slate-700 mb-1.5">Mensagem <span class="text-red-500">*</span></label>
            <textarea
              id="mensagem"
              name="mensagem"
              required
              rows="5"
              placeholder="Descreva brevemente sua necessidade ou dúvida..."
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#3a8d44] focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#1a3044] hover:bg-[#243d54] text-white font-bold py-3.5 px-6 rounded-full text-sm transition-colors flex items-center justify-center gap-2"
          >
            <Icon name="tabler:send" class="w-4 h-4" />
            Enviar mensagem
          </button>

          <p id="form-success" class="hidden text-center text-sm text-[#3a8d44] font-semibold pt-2">
            ✓ Mensagem enviada com sucesso! Retornaremos em breve.
          </p>
          <p id="form-error" class="hidden text-center text-sm text-red-500 font-semibold pt-2">
            Ocorreu um erro. Tente novamente ou entre em contato pelo WhatsApp.
          </p>
        </form>
      </div>

      <!-- WHATSAPP + INFO -->
      <div class="tx-fade tx-fade-delay-1">
        <p class="text-sm text-[#1a3044] font-bold tracking-widest uppercase mb-2">Prefere falar diretamente?</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[#1a3044] mb-2">Chame no WhatsApp</h2>
        <div class="w-16 h-1 bg-[#25d366] rounded-full mb-8"></div>

        <p class="text-slate-600 text-sm leading-relaxed mb-6">
          Nossa equipe costuma responder rapidamente pelo WhatsApp. Se preferir uma conversa mais direta e ágil, é só chamar!
        </p>

        <a href="https://wa.me/5531994915126?text=Olá!%20Gostaria%20de%20falar%20com%20a%20equipe%20da%20Triaxis."
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#25d366] hover:bg-[#1ebe5a] text-white font-bold px-8 py-4 rounded-full text-base transition-colors shadow-md w-full justify-center mb-10">
          <Icon name="tabler:brand-whatsapp" class="w-6 h-6" />
          Iniciar conversa no WhatsApp
        </a>

        <div class="bg-slate-50 rounded-2xl p-6 space-y-5">
          <h3 class="text-sm font-bold text-[#1a3044] uppercase tracking-wider">Informações de contato</h3>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg bg-white border border-slate-200 flex items-center justify-center flex-shrink-0">
              <Icon name="tabler:map-pin" class="w-4 h-4 text-orange-500" />
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-0.5">Regiões atendidas</p>
              <p class="text-sm text-slate-700">Ouro Preto · Mariana · Belo Horizonte</p>
              <p class="text-xs text-slate-500">Estado de Minas Gerais</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg bg-white border border-slate-200 flex items-center justify-center flex-shrink-0">
              <Icon name="tabler:clock" class="w-4 h-4 text-[#1a3044]" />
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-0.5">Horário de atendimento</p>
              <p class="text-sm text-slate-700">Segunda a Sexta — 8h às 18h</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg bg-white border border-slate-200 flex items-center justify-center flex-shrink-0">
              <Icon name="tabler:mail" class="w-4 h-4 text-[#1a3044]" />
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-0.5">E-mail</p>
              <a href="mailto:daiannalana@triaxisdesenvolvimento.com.br" class="text-sm text-[#1a3044] hover:text-[#3a8d44] transition-colors break-all">
                daiannalana@triaxisdesenvolvimento.com.br
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg bg-white border border-slate-200 flex items-center justify-center flex-shrink-0">
              <Icon name="tabler:brand-linkedin" class="w-4 h-4 text-[#0077b5]" />
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-0.5">LinkedIn</p>
              <a href="https://www.linkedin.com/company/triaxis-engenharia/" target="_blank" rel="noopener noreferrer"
                class="text-sm text-[#1a3044] hover:text-[#3a8d44] transition-colors">
                Triaxis Engenharia
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-[#1a3044] py-14 px-4">
    <div class="max-w-3xl mx-auto text-center tx-fade">
      <p class="text-sm text-[#6fcf7f] font-bold tracking-widest uppercase mb-3">Pronto para começar?</p>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        O primeiro passo é uma conversa.
      </h2>
      <p class="text-slate-300 mb-8 leading-relaxed">
        Nosso diagnóstico inicial é gratuito. Fale com a Triaxis e descubra como podemos ajudar sua empresa a crescer com segurança, eficiência e conformidade.
      </p>
      <a href="https://wa.me/5531994915126?text=Olá!%20Gostaria%20de%20agendar%20um%20diagnóstico%20gratuito%20com%20a%20Triaxis."
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1ebe5a] text-white font-bold px-8 py-3.5 rounded-full text-base transition-colors shadow-md">
        <Icon name="tabler:brand-whatsapp" class="w-5 h-5" />
        Agendar diagnóstico gratuito
      </a>
    </div>
  </section>

</Layout>

<style is:global>
  .contact-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
  }

  .tx-fade { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .tx-fade.tx-visible { opacity: 1; transform: translateY(0); }
  .tx-fade-delay-1 { transition-delay: 0.15s; }
</style>

<script>
  // Animações de entrada
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('tx-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.tx-fade').forEach(el => observer.observe(el));

  // Feedback do formulário Formspree (fetch assíncrono)
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
        btn.textContent = 'Mensagem enviada!';
      } else {
        throw new Error();
      }
    } catch {
      error?.classList.remove('hidden');
      success?.classList.add('hidden');
      btn.disabled = false;
      btn.textContent = 'Enviar mensagem';
    }
  });
</script>

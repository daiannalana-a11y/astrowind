---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Fale Conosco — Triaxis Consultoria',
};
---

<Layout metadata={metadata}>
  <section class="bg-slate-50 dark:bg-slate-900 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        
        <div>
          <p class="text-orange-600 font-bold uppercase tracking-wider text-sm mb-4">Fale Conosco</p>
          <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
            Vamos iniciar a transformação juntos.
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed">
            Seja para um diagnóstico inicial, dúvidas sobre conformidade legal ou para otimizar os processos da sua indústria, nossa equipe está pronta para apresentar soluções práticas e mensuráveis.
          </p>

          <div class="space-y-6">
            <div class="flex items-center group">
              <div class="w-12 h-12 bg-green-50 text-green-600 rounded-lg flex items-center justify-center mr-4 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white">WhatsApp / Telefone</p>
                <p class="text-slate-600 dark:text-slate-400">(31) 99491-5126</p>
              </div>
            </div>

            <div class="flex items-center group">
              <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center mr-4 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white">E-mail Corporativo</p>
                <p class="text-slate-600 dark:text-slate-400">contato@triaxis.com.br</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-8 md:p-10 rounded-3xl shadow-2xl border border-slate-100 dark:border-slate-700">
          <form class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nome Completo *</label>
                <input type="text" placeholder="Ex: João Silva" class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all">
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Empresa / Indústria</label>
                <input type="text" placeholder="Ex: Vale S.A." class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all">
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">E-mail Corporativo *</label>
              <input type="email" placeholder="joao@empresa.com.br" class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all">
            </div>

            <div>
              <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Como podemos ajudar? *</label>
              <textarea rows="4" placeholder="Descreva brevemente sua necessidade ou desafio atual..." class="w-full px-4 py-3 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-blue-500 outline-none transition-all resize-none"></textarea>
            </div>

            <button type="submit" class="w-full py-4 bg-[#0a2540] hover:bg-slate-800 text-white font-bold rounded-xl shadow-lg transition-all transform hover:-translate-y-1">
              Enviar Mensagem
            </button>
            
            <p class="text-center text-xs text-slate-400 mt-4">
              Retornaremos o contato em até 24 horas úteis.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>
</Layout>

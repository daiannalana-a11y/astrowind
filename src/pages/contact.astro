---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Fale Conosco — Triaxis Consultoria',
  description: 'Inicie sua transformação conosco. Entre em contato para diagnósticos, dúvidas ou projetos.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Fale Conosco"
    title="Vamos iniciar a transformação juntos."
    subtitle="Seja para um diagnóstico inicial, dúvidas sobre conformidade legal ou para otimizar os processos da sua indústria, nossa equipe está pronta para apresentar soluções práticas e mensuráveis."
  />

  <ContactUs
    id="form"
    title="Envie uma mensagem"
    subtitle="Retornaremos o contato em até 24 horas úteis."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nome Completo *',
        placeholder: 'Ex: João Silva',
      },
      {
        type: 'text',
        name: 'empresa',
        label: 'Empresa / Indústria',
        placeholder: 'Ex: Vale S.A.',
      },
      {
        type: 'email',
        name: 'email',
        label: 'E-mail Corporativo *',
        placeholder: 'joao@empresa.com.br',
      },
    ]}
    textarea={{
      label: 'Como podemos ajudar? *',
      placeholder: 'Descreva brevemente sua necessidade ou desafio atual...',
    }}
    disclaimer={{
      label: 'Ao enviar este formulário, você concorda com o processamento dos seus dados pessoais conforme nossa Política de Privacidade.',
    }}
    button="Enviar Mensagem"
  />

  <Features2
    title="Canais Diretos"
    items={[
      {
        title: 'WhatsApp / Telefone',
        description: '(31) 99491-5126',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'E-mail Corporativo',
        description: 'contato@triaxis.com.br',
        icon: 'tabler:mail',
      },
      {
        title: 'Onde Estamos',
        description: 'Belo Horizonte, MG e Região',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>

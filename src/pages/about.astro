---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks'; // Adicionamos esta linha para os links funcionarem 100%

const metadata = {
  title: 'Quem Somos — Triaxis Consultoria',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Quem Somos"
    title="Especialistas que unem técnica, responsabilidade e resultado"
    subtitle="A Triaxis nasceu da convicção de que conformidade legal e crescimento sustentável andam juntos. Somos engenheiros comprometidos com o desenvolvimento seguro e eficiente das empresas brasileiras."
    image={{ src: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=2070&q=80', alt: 'Equipe Triaxis' }}
  />

  <Features
    id="missao-visao-valores"
    tagline="Nossa Essência"
    title="Pilares Estratégicos"
    items={[
      {
        title: 'Missão',
        description: 'Oferecer soluções técnicas de excelência em engenharia ambiental, de produção e segurança do trabalho, contribuindo para que as empresas operem com segurança, eficiência e responsabilidade.',
        icon: 'tabler:target',
      },
      {
        title: 'Visão',
        description: 'Ser referência regional em consultoria integrada de engenharia, reconhecida pela qualidade técnica, agilidade e pelo impacto positivo gerado nos negócios de nossos clientes.',
        icon: 'tabler:eye',
      },
      {
        title: 'Excelência Técnica',
        description: 'Cada entrega é baseada em rigor metodológico, legislação atualizada e domínio profundo das normas técnicas aplicáveis.',
        icon: 'tabler:medal',
      },
      {
        title: 'Ética e Transparência',
        description: 'Atuamos com integridade em todas as etapas, mantendo o cliente informado e alinhado com cada decisão tomada.',
        icon: 'tabler:shield',
      },
      {
        title: 'Comprometimento com Resultados',
        description: 'Não entregamos apenas relatórios — entregamos soluções que funcionam na prática e geram valor real para o negócio.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Sustentabilidade',
        description: 'Acreditamos que desenvolvimento econômico e responsabilidade ambiental e social não são opostos — são complementares.',
        icon: 'tabler:leaf',
      },
    ]}
  />

  <Stats
    title="Triaxis em números"
    stats={[
      { title: 'Empresas atendidas', amount: '80+' },
      { title: 'Projetos entregues', amount: '200+' },
      { title: 'Anos de experiência', amount: '10+' },
      { title: 'Especialistas', amount: '5' },
    ]}
  />

  <Steps2
    title="Nossa Equipe"
    tagline="Profissionais"
    subtitle="Engenheiros com formação sólida, experiência de campo e atualização constante nas legislações e normas vigentes."
    items={[
      {
        title: 'Engenharia Ambiental',
        description: 'Especialistas em licenciamento, gestão de resíduos, monitoramento ambiental e conformidade com a legislação federal e estadual.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Engenharia de Produção',
        description: 'Profissionais com experiência em otimização de processos, gestão industrial e implantação de metodologias de melhoria contínua.',
        icon: 'tabler:settings',
      },
      {
        title: 'Segurança do Trabalho',
        description: 'Técnicos e engenheiros especializados em NRs, PCMSO, PGR, laudos e treinamentos obrigatórios.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <CallToAction
    title="Vamos trabalhar juntos?"
    subtitle="Entre em contato e conte para nós o desafio da sua empresa. Teremos prazer em ajudar."
    actions={[
      { variant: 'primary', text: 'Fale com a Triaxis', href: getPermalink('/contact') },
    ]}
  />

</Layout>

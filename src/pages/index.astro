---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança',
  description: 'Consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho para empresas que buscam conformidade e crescimento.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Consultoria Especializada"
    title="Transformamos exigências legais em oportunidades de crescimento sustentável"
    subtitle="Somos uma consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho para empresas que precisam estar em conformidade e querem crescer de forma segura e eficiente."
    actions={[
      { variant: 'primary', text: 'Agende uma conversa', href: '/contact' },
      { text: 'Nossos Serviços', href: '#servicos-home' },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=2070&q=80', 
      alt: 'Triaxis Consultoria Escritório' 
    }}
  />

  <Features
    id="features"
    tagline="Por que a Triaxis?"
    title="Nossos Diferenciais"
    columns={3}
    classes={{
      container: 'max-w-7xl mx-auto py-12 md:py-16',
      title: 'text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center',
      items: {
        container: 'relative flex flex-row items-start p-4',
        title: 'text-xl font-bold ml-4 text-gray-900 dark:text-white',
        description: 'text-muted mt-2 ml-4 leading-relaxed text-sm',
        icon: 'flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-slate-800 dark:bg-slate-700 text-white p-3 shadow-md',
      },
    }}
    items={[
      {
        title: 'Expertise Técnica',
        description: 'Equipe altamente qualificada com experiência sólida em consultoria e processos industriais.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Soluções Personalizadas',
        description: 'Abordagem sob medida para cada cliente, garantindo resultados aplicáveis à rotina.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Visão Sustentável',
        description: 'Foco no equilíbrio entre eficiência operacional e conformidade socioambiental (ESG).',
        icon: 'tabler:world',
      },
    ]}
  />

  <Content
    id="quem-somos-home"
    isReversed
    tagline="Quem Somos"
    title="Muito além da teoria. Entregamos prática."
    image={{
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80',
      alt: 'Equipe Triaxis trabalhando',
    }}
  >
    <Fragment slot="content">
      <p class="mb-4 text-muted dark:text-slate-400 text-lg leading-relaxed">
        A Triaxis nasceu da união de profissionais com experiência sólida e complementar em Engenharia Ambiental, Engenharia de Produção e Segurança do Trabalho. Identificamos uma lacuna clara no mercado: empresas precisavam de uma consultoria capaz de unir excelência técnica e visão estratégica.
      </p>
      <p class="mb-8 text-muted dark:text-slate-400 text-lg leading-relaxed">
        Com uma equipe multidisciplinar, transformamos demandas técnicas rigorosas em ações claras. Nosso foco é garantir conformidade e eficiência operacional.
      </p>
      
      <div class="flex flex-wrap gap-6 items-center">
        <a href="/contact" class="text-primary font-bold hover:underline flex items-center text-lg">
          Falar com nossa Equipe <span class="ml-2">→</span>
        </a>
        <a href="/about" class="text-gray-500 dark:text-slate-400 font-semibold hover:underline border-l border-gray-300 dark:border-slate-700 pl-6 text-lg">
          Saiba mais sobre nós
        </a>
      </div>
    </Fragment>
  </Content>

  <section id="servicos-home" class="bg-slate-50 dark:bg-slate-800 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white uppercase font-heading mb-12">
        Nossas Especialidades
      </h2>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-green-700 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow">
            <h3 class="text-lg font-bold mb-4">Consultoria Ambiental</h3>
            <ul class="space-y-2 text-left inline-block">
              {['Licenciamento e Outorgas', 'Gestão de Resíduos', 'Recuperação de Áreas (PRAD)', 'Inventários de GEE e ESG'].map((item) => (
                <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-green-700 mr-2 font-bold">✓</span> {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0">
            <a href="/services#ambiental" class="block w-full py-2 text-center border border-green-700 text-green-700 text-xs font-bold rounded hover:bg-green-700 hover:text-white transition-all"> VER DETALHES </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-blue-700 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow">
            <h3 class="text-lg font-bold mb-4">Engenharia de Produção</h3>
            <ul class="space-y-2 text-left inline-block">
              {['Diagnóstico Lean e Eficiência', 'Mapeamento de Processos', 'Implementação 5S e Layout', 'Gestão de Indicadores'].map((item) => (
                <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-blue-700 mr-2 font-bold">✓</span> {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0">
            <a href="/services#producao" class="block w-full py-2 text-center border border-blue-700 text-blue-700 text-xs font-bold rounded hover:bg-blue-700 hover:text-white transition-all"> VER DETALHES </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-orange-600 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow text-center">
            <h3 class="text-lg font-bold mb-4">Segurança do Trabalho</h3>
            <ul class="space-y-2 text-left inline-block">
              {['Elaboração de PGR e LTCAT', 'Treinamentos (NRs)', 'Laudos de Insalubridade', 'Gestão de EPIs e CIPA'].map((item) => (
                <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-orange-600 mr-2 font-bold">✓</span> {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0">
            <a href="/services#seguranca" class="block w-full py-2 text-center border border-orange-600 text-orange-600 text-xs font-bold rounded hover:bg-orange-600 hover:text-white transition-all"> VER DETALHES </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-24 bg-white dark:bg-slate-900 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-16 text-center">
        <p class="text-sm text-green-700 font-bold tracking-widest uppercase mb-2">Como Trabalhamos</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white font-heading"> Nossa Metodologia </h2>
      </div>

      <div class="relative flex flex-wrap md:flex-nowrap justify-between gap-12 md:gap-4">
        <div class="relative flex flex-col items-center text-center flex-1 min-w-[200px]">
          <div class="w-16 h-16 rounded-full border-4 border-green-700 flex items-center justify-center text-2xl font-bold text-gray-800 dark:text-white bg-white dark:bg-slate-800 shadow-xl mb-6 z-10"> 1 </div>
          <h3 class="text-xl font-bold mb-3">Diagnóstico</h3>
          <p class="text-sm text-muted dark:text-slate-400 px-4"> Análise técnica detalhada da situação atual, identificando gargalos e riscos. </p>
          <div class="hidden md:block absolute top-8 left-[calc(50%+32px)] w-[calc(100%-64px)] h-0.5 bg-gray-100 dark:bg-slate-700"></div>
        </div>
        <div class="relative flex flex-col items-center text-center flex-1 min-w-[200px]">
          <div class="w-16 h-16 rounded-full border-4 border-blue-700 flex items-center justify-center text-2xl font-bold text-gray-800 dark:text-white bg-white dark:bg-slate-800 shadow-xl mb-6 z-10"> 2 </div>
          <h3 class="text-xl font-bold mb-3">Planejamento</h3>
          <p class="text-sm text-muted dark:text-slate-400 px-4"> Desenvolvimento de matriz de obrigações e plano de ação executável. </p>
          <div class="hidden md:block absolute top-8 left-[calc(50%+32px)] w-[calc(100%-64px)] h-0.5 bg-gray-100 dark:bg-slate-700"></div>
        </div>
        <div class="relative flex flex-col items-center text-center flex-1 min-w-[200px]">
          <div class="w-16 h-16 rounded-full border-4 border-green-700 flex items-center justify-center text-2xl font-bold text-gray-800 dark:text-white bg-white dark:bg-slate-800 shadow-xl mb-6 z-10"> 3 </div>
          <h3 class="text-xl font-bold mb-3">Implantação</h3>
          <p class="text-sm text-muted dark:text-slate-400 px-4"> Execução das soluções na prática, com treinamento e criação de rotinas. </p>
          <div class="hidden md:block absolute top-8 left-[calc(50%+32px)] w-[calc(100%-64px)] h-0.5 bg-gray-100 dark:bg-slate-700"></div>
        </div>
        <div class="relative flex flex-col items-center text-center flex-1 min-w-[200px]">
          <div class="w-16 h-16 rounded-full border-4 border-blue-700 flex items-center justify-center text-2xl font-bold text-gray-800 dark:text-white bg-white dark:bg-slate-800 shadow-xl mb-6 z-10"> 4 </div>
          <h3 class="text-xl font-bold mb-3">Sustentação</h3>
          <p class="text-sm text-muted dark:text-slate-400 px-4"> Monitoramento de KPIs e gestão contínua para resultados duradouros. </p>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Pronto para colocar sua empresa em conformidade?"
    subtitle="Entre em contato e descubra como a Triaxis pode ajudar sua operação."
    actions={[{ variant: 'primary', text: 'Fale com um especialista', href: '/contact' }]}
  />

</Layout>

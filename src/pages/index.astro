---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança',
  description: 'Consultoria multidisciplinar para empresas que buscam conformidade legal e eficiência operacional.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Consultoria Especializada"
    title="Transformamos exigências legais em oportunidades de crescimento sustentável"
    subtitle="Somos uma consultoria multidisciplinar especializada em Meio Ambiente, Produção e Segurança do Trabalho para indústrias que buscam conformidade e crescimento eficiente."
    actions={[
      { variant: 'primary', text: 'Agende uma conversa', href: '/contact' },
      { text: 'Nossos Serviços', href: '#servicos-home' },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=2070&q=80', 
      alt: 'Triaxis Consultoria' 
    }}
  />

  <Content
    id="features-harmonized"
    isReversed
    tagline="Por que a Triaxis?"
    title="Nossos Diferenciais"
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=2070&q=80',
      alt: 'Equipe técnica Triaxis',
    }}
    classes={{
      container: 'max-w-7xl mx-auto py-16 md:py-24 bg-white',
      title: 'text-3xl md:text-4xl font-bold tracking-tight mb-8 font-heading',
    }}
  >
    <Fragment slot="content">
      <p class="text-lg text-muted mb-12">
        Unimos expertise técnica multidisciplinar e uma visão estratégica para entregar diagnósticos precisos e soluções aplicáveis à rotina de cada cliente.
      </p>

      <Features
        id="differentials-list"
        columns={1}
        items={[
          {
            title: 'Expertise Técnica',
            description: 'Equipe altamente qualificada em consultoria ambiental, segurança e processos industriais.',
            icon: 'tabler:shield-check',
          },
          {
            title: 'Soluções Personalizadas',
            description: 'Abordagem sob medida, garantindo resultados aplicáveis e resultados mensuráveis.',
            icon: 'tabler:trending-up',
          },
          {
            title: 'Visão Sustentável',
            description: 'Foco no equilíbrio entre eficiência operacional e conformidade socioambientais (ESG).',
            icon: 'tabler:world',
          },
        ]}
        classes={{
          container: 'max-w-none p-0',
          items: {
            container: 'flex flex-row items-start mb-6', // Ícone ao lado do texto
            title: 'text-xl font-bold text-gray-900',
            description: 'text-muted mt-2',
            icon: 'flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-slate-900 text-white p-3 shadow-md', // Círculo escuro premium
          },
        }}
      />
    </Fragment>
  </Content>

  <section id="servicos-home" class="bg-slate-50 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold uppercase tracking-widest font-heading mb-12">
        Nossas Especialidades
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-sm border-t-4 border-t-green-700 flex flex-col h-full">
          <div class="p-6 flex-grow">
            <h3 class="text-lg font-bold mb-4">Consultoria Ambiental</h3>
            <ul class="space-y-2 text-left inline-block">
              {['Licenciamento Ambiental', 'Gestão de Resíduos', 'Outorgas d\'Água', 'ESG'].map(i => (
                <li class="flex items-center text-sm"><span class="text-green-700 mr-2">✓</span>{i}</li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0"><a href="/contact" class="block py-1.5 px-6 border border-green-700 text-green-700 text-xs font-bold rounded">SOLICITAR PROPOSTA</a></div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border-t-4 border-t-blue-700 flex flex-col h-full">
          <div class="p-6 flex-grow">
            <h3 class="text-lg font-bold mb-4">Engenharia de Produção</h3>
            <ul class="space-y-2 text-left inline-block">
              {['Diagnóstico Lean Manufacturing', 'Mapeamento VSM', 'Processos', 'Otimização'].map(i => (
                <li class="flex items-center text-sm"><span class="text-blue-700 mr-2">✓</span>{i}</li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0"><a href="/contact" class="block py-1.5 px-6 border border-blue-700 text-blue-700 text-xs font-bold rounded">SOLICITAR PROPOSTA</a></div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border-t-4 border-t-orange-600 flex flex-col h-full">
          <div class="p-6 flex-grow">
            <h3 class="text-lg font-bold mb-4">Segurança do Trabalho</h3>
            <ul class="space-y-2 text-left inline-block">
              {['PGR e LTCAT', 'Treinamentos (NRs)', 'Gestão CIPA', 'Laudos'].map(i => (
                <li class="flex items-center text-sm"><span class="text-orange-600 mr-2">✓</span>{i}</li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0"><a href="/contact" class="block py-1.5 px-6 border border-orange-600 text-orange-600 text-xs font-bold rounded">SOLICITAR PROPOSTA</a></div>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Pronto para colocar sua empresa em conformidade?"
    subtitle="Fale com nossa equipe técnica e receba um diagnóstico especializado."
    actions={[{ variant: 'primary', text: 'Agende uma conversa', href: '/contact' }]}
  />

</Layout>

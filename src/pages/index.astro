---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Engenharia e Consultoria',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero>
      <Fragment slot="title">
        <div class="hero-container">
          <p class="tagline">DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA</p>
          
          <h1 class="main-title">
            Transformamos Exigências Legais<br/>
            em Oportunidades de<br/>
            <span class="highlight">Crescimento Sustentável</span>
          </h1>
          
          <p class="hero-subtitle">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>

          <div class="button-wrapper">
            <a href="/contact" class="btn-triaxis btn-orange">
              Agende uma conversa
            </a>
            <a href="#servicos-home" class="btn-triaxis btn-white">
              Nossos Serviços
            </a>
          </div>
        </div>
      </Fragment>
    </Hero>

    <section class="section-diferenciais">
      <div class="container-custom">
        <p class="section-tagline">Por que a Triaxis?</p>
        <h2 class="section-title">Nossos Diferenciais</h2>
        
        <div class="grid-diferenciais">
          <div class="custom-card card-green">
            <h3>Técnica e Gestão</h3>
            <p>Processos e pessoas em harmonia.</p>
          </div>
          <div class="custom-card card-blue">
            <h3>Soluções Sob Medida</h3>
            <p>Planos de ação personalizados.</p>
          </div>
          <div class="custom-card card-orange">
            <h3>Multidisciplinaridade</h3>
            <p>Ambiental, Produção e Segurança.</p>
          </div>
        </div>
      </div>
    </section>

    <Content
      isReversed
      image={{ src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80', alt: 'Equipe' }}
    >
      <Fragment slot="content">
        <h2 class="text-3xl font-bold text-[#1a3044] mb-4">Resultados que surgem da integração.</h2>
        <p class="text-slate-600 border-l-4 border-[#3a8d44] pl-4">Unimos rigor normativo e visão estratégica para transformar indústrias.</p>
      </Fragment>
    </Content>

    <CallToAction
      title="Pronto para começar?"
      actions={[{ variant: 'primary', text: 'Contato', href: '/contact' }]}
    />
  </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* 1. MENU SUPERIOR */
  header#header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 2px solid #e2e8f0 !important;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
  }
  header#header.header-custom a { color: #1a3044 !important; font-weight: 600; text-decoration: none; }

  /* 2. HERO E TEXTOS */
  .hero-container { margin-top: -60px; text-align: center; display: block; }
  .tagline { color: #3a8d44; font-weight: 800; font-size: 12px; letter-spacing: 2px; margin-bottom: 15px; text-transform: uppercase; }
  .main-title { color: #1a3044; font-weight: 800; font-size: 48px; line-height: 1.1; letter-spacing: -1px; margin-bottom: 20px; }
  .highlight { color: #3a8d44; }
  .hero-subtitle { color: #64748b; font-size: 18px; margin: 20px auto; max-width: 700px; line-height: 1.6; }

  /* 3. BOTÕES (CORREÇÃO FINAL DO TEXTO) */
  .button-wrapper {
    display: flex !important;
    flex-direction: row !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 20px !important;
    margin-top: 40px !important;
  }

  .btn-triaxis {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    border-radius: 50px !important;
    padding: 0 35px !important;
    height: 55px !important;
    min-width: 220px !important;
    transition: all 0.2s ease;
    line-height: 1 !important;
    white-space: nowrap !important;
  }

  .btn-orange { background-color: #ea580c !important; color: white !important; box-shadow: 0 10px 20px rgba(234, 88, 12, 0.3) !important; border: none !important; }
  .btn-white { background-color: white !important; color: #1a3044 !important; border: 2px solid #e2e8f0 !important; }
  .btn-triaxis:hover { transform: translateY(-3px); }

  /* 4. SEÇÃO DIFERENCIAIS */
  .section-diferenciais { padding: 80px 0; background: white; border-top: 1px solid #f1f5f9; }
  .container-custom { max-width: 1200px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .section-tagline { color: #3a8d44; font-weight: 700; text-transform: uppercase; font-size: 14px; margin-bottom: 10px; }
  .section-title { font-size: 36px; font-weight: 800; color: #1a3044; margin-bottom: 50px; }
  
  .grid-diferenciais { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }
  .custom-card { background: #f8fafc; padding: 40px; border-radius: 30px; transition: 0.3s; text-align: center; }
  .custom-card h3 { font-weight: 800; color: #1a3044; margin-bottom: 10px; font-size: 20px; }
  .card-green { border-bottom: 5px solid #3a8d44; }
  .card-blue { border-bottom: 5px solid #1a3044; }
  .card-orange { border-bottom: 5px solid #ea580c; }
</style>

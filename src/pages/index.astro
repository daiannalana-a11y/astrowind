---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Engenharia e Consultoria',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero>
      <Fragment slot="title">
        <div class="hero-container">
          <p class="tagline">DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA</p>
          
          <h1 class="main-title">
            Transformamos Exigências Legais<br/>
            em Oportunidades de<br/>
            <span class="highlight">Crescimento Sustentável</span>
          </h1>
          
          <p class="subtitle">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>

          <div class="button-wrapper">
            <a href="/contact" class="btn-new btn-orange">
              Agende uma conversa
            </a>
            <a href="#servicos-home" class="btn-new btn-white">
              Nossos Serviços
            </a>
          </div>
        </div>
      </Fragment>
    </Hero>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <p class="text-[#3a8d44] font-bold uppercase tracking-widest text-sm mb-2">Por que a Triaxis?</p>
        <h2 class="text-4xl font-bold text-[#1a3044] mb-12">Nossos Diferenciais</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="custom-card">
            <h3 class="font-bold text-lg text-[#1a3044]">Técnica e Gestão</h3>
            <p class="text-slate-600">Processos e pessoas em harmonia.</p>
          </div>
          <div class="custom-card">
            <h3 class="font-bold text-lg text-[#1a3044]">Soluções Sob Medida</h3>
            <p class="text-slate-600">Planos de ação personalizados.</p>
          </div>
          <div class="custom-card">
            <h3 class="font-bold text-lg text-[#1a3044]">Multidisciplinaridade</h3>
            <p class="text-slate-600">Ambiental, Produção e Segurança.</p>
          </div>
        </div>
      </div>
    </section>

    <Content
      isReversed
      image={{ src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80', alt: 'Equipe' }}
    >
      <Fragment slot="content">
        <h2 class="text-3xl font-bold text-[#1a3044] mb-4">Resultados que surgem da integração.</h2>
        <p class="text-slate-600 border-l-4 border-[#3a8d44] pl-4">Unimos rigor normativo e visão estratégica para transformar indústrias.</p>
      </Fragment>
    </Content>

    <CallToAction
      title="Pronto para começar?"
      actions={[{ variant: 'primary', text: 'Contato', href: '/contact', class: 'bg-orange-600' }]}
    />
  </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* 1. RESET E FIX DO MENU */
  header#header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 2px solid #e2e8f0 !important;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
  }
  header#header.header-custom a { color: #1a3044 !important; font-weight: 600; text-decoration: none; }

  /* 2. ESTILO DO HERO (TEXTO) */
  .hero-container { margin-top: -60px; text-align: center; }
  .tagline { color: #3a8d44; font-weight: 800; font-size: 12px; letter-spacing: 2px; margin-bottom: 15px; }
  .main-title { color: #1a3044; font-weight: 800; font-size: 48px; line-height: 1; letter-spacing: -2px; }
  .highlight { color: #3a8d44; }
  .subtitle { color: #64748b; font-size: 18px; margin-top: 20px; max-width: 700px; margin-left: auto; margin-right: auto; }

  /* 3. OS NOVOS BOTÕES (IMUNES AO TEMA) */
  .button-wrapper {
    display: flex !important;
    flex-direction: row !important;
    justify-content: center !important;
    gap: 20px !important;
    margin-top: 40px !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  .btn-new {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    border-radius: 50px !important;
    padding: 0 35px !important; /* Espaço nas laterais */
    height: 55px !important;    /* Altura fixa para o texto não encostar */
    min-width: 220px !important;
    transition: all 0.2s ease;
  }

  .btn-orange {
    background-color: #ea580c !important;
    color: white !important;
    box-shadow: 0 10px 20px rgba(234, 88, 12, 0.3) !important;
  }

  .btn-white {
    background-color: white !important;
    color: #1a3044 !important;
    border: 2px solid #e2e8f0 !important;
  }

  .btn-new:hover { transform: translateY(-3px); }

  /* 4. CARDS */
  .custom-card {
    background: #f8fafc;
    padding: 40px;
    border-radius: 30px;
    border-bottom: 4px solid #1a3044;
  }
</style>

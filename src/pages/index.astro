---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança do Trabalho',
  description: 'Consultoria multidisciplinar especializada em Meio Ambiente, Produção e Segurança do Trabalho.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA"
    actions={[
      { 
        variant: 'primary', 
        text: 'Agende uma conversa', 
        href: '/contact', 
        class: 'bg-orange-600 hover:bg-orange-700 text-white px-6 py-2 rounded-full font-bold text-xs shadow-md transition-all border-none' 
      },
      { 
        text: 'Nossos Serviços', 
        href: '#servicos-home', 
        class: 'border border-slate-300 hover:border-[#1a3044] text-[#1a3044] px-6 py-2 rounded-full font-bold text-xs transition-all' 
      },
    ]}
  >
    <Fragment slot="title">
      <div class="pt-2 md:pt-4 -mt-12 pb-0 max-w-5xl mx-auto leading-[0.95] tracking-tighter text-[#1a3044] dark:text-white font-bold text-3xl md:text-5xl">
        <span class="block">Transformamos Exigências Legais</span>
        <span class="block">em Oportunidades de</span>
        <span class="text-[#3a8d44] block mt-[-4px]">Crescimento Sustentável</span>
      </div>
    </Fragment>
    
    <Fragment slot="subtitle">
      <div class="max-w-3xl mx-auto text-sm md:text-base text-slate-600 dark:text-slate-400 leading-snug font-sans mt-1 mb-6">
        Consultoria Multidisciplinar Especializada em Engenharia Ambiental, <br class="hidden md:block" />
        Engenharia de Produção e Segurança do Trabalho.
      </div>
    </Fragment>
  </Hero>

  <section class="py-8 md:py-10 bg-white dark:bg-slate-900 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-8 text-center max-w-3xl mx-auto">
        <p class="text-[10px] text-[#3a8d44] font-bold tracking-widest uppercase mb-1 font-heading">Por que a Triaxis?</p>
        <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-2 font-heading text-[#1a3044]">
          Nossos Diferenciais
        </h2>
        <div class="w-16 h-1 bg-orange-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-slate-50 p-6 rounded-[24px] border-b-4 border-[#3a8d44] shadow-sm flex flex-col items-center text-center transition-all hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-green-50 text-[#3a8d44] flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M12 3v12" /><path d="M12 18h.01" /><path d="M12 21a9 9 0 0 1 0 -18" /></svg>
          </div>
          <h3 class="text-base font-bold mb-1 font-heading text-[#1a3044]">Técnica e Gestão</h3>
          <p class="text-xs text-slate-600 italic">Processos e pessoas trabalhando em conjunto.</p>
        </div>

        <div class="bg-slate-50 p-6 rounded-[24px] border-b-4 border-[#1a3044] shadow-sm flex flex-col items-center text-center transition-all hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-blue-50 text-[#1a3044] flex items-center justify-center mb-4">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M3 17l6 -6l4 4l8 -8" /><path d="M14 7l7 0l0 7" /></svg>
          </div>
          <h3 class="text-base font-bold mb-1 font-heading text-[#1a3044]">Soluções Personalizadas</h3>
          <p class="text-xs text-slate-600 italic">Planos de ação sob medida para seu negócio.</p>
        </div>

        <div class="bg-slate-50 p-6 rounded-[24px] border-b-4 border-orange-500 shadow-sm flex flex-col items-center text-center transition-all hover:-translate-y-1">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-orange-600 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" /><path d="M3.6 9h16.8" /><path d="M3.6 15h16.8" /></svg>
          </div>
          <h3 class="text-base font-bold mb-1 font-heading text-[#1a3044]">Atuação Multidisciplinar</h3>
          <p class="text-xs text-slate-600 italic">Engenharia Ambiental, Produção e Segurança.</p>
        </div>
      </div>
    </div>
  </section>

  <Content
    id="quem-somos-home"
    isReversed
    image={{
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80',
      alt: 'Equipe Triaxis trabalhando',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-orange-600 font-bold uppercase tracking-widest text-[10px] mb-2 font-heading">
        Engenharia • Consultoria • Assessoria
      </h3>
      <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-[#1a3044] font-heading leading-tight mb-4">
        Resultados que surgem da integração entre áreas do conhecimento.
      </h2>
      <p class="text-sm text-slate-600 leading-relaxed mb-6 font-sans border-l-4 border-[#3a8d44] pl-4">
        A Triaxis une rigor normativo e visão estratégica de negócio para oferecer consultoria capaz de transformar a realidade operacional das indústrias.
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a href="/about" class="bg-[#1a3044] text-white px-5 py-2 rounded-full font-bold text-xs shadow-md hover:bg-[#25425d] transition-all">Saiba mais</a>
        <a href="/contact" class="font-bold text-[#3a8d44] hover:text-green-900 transition-colors flex items-center text-xs">Falar com nossa Equipe <span class="ml-2">→</span></a>
      </div>
    </Fragment>
  </Content>

  <section id="servicos-home" class="bg-slate-50 dark:bg-slate-800 py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-xl md:text-2xl font-bold uppercase tracking-widest font-heading mb-8 text-[#1a3044]">Nossas Especialidades</h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        
        <div class="flex flex-col bg-white rounded-xl shadow-sm border-t-[6px] border-t-[#3a8d44] p-8">
          <h3 class="text-lg font-bold mb-4 font-heading text-[#1a3044]">Consultoria Ambiental</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow font-sans text-xs">
            {['Licenciamento Ambiental', 'Gestão de Resíduos', 'Outorgas'].map(i => (
              <li class="flex items-center text-slate-600"><span class="text-[#3a8d44] mr-2 font-bold">✓</span> {i}</li>
            ))}
          </ul>
          <a href="/services#ambiental" class="py-2 border border-[#3a8d44] text-[#3a8d44] text-[10px] font-bold rounded-full hover:bg-[#3a8d44] hover:text-white transition-all text-center uppercase tracking-widest">VER DETALHES</a>
        </div>

        <div class="flex flex-col bg-white rounded-xl shadow-sm border-t-[6px] border-t-[#1a3044] p-8">
          <h3 class="text-lg font-bold mb-4 font-heading text-[#1a3044]">Engenharia de Produção</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow font-sans text-xs">
            {['Diagnóstico Lean', 'Mapeamento VSM', 'Layout'].map(i => (
              <li class="flex items-center text-slate-600"><span class="text-blue-700 mr-2 font-bold">✓</span> {i}</li>
            ))}
          </ul>
          <a href="/services#producao" class="py-2 border border-[#1a3044] text-[#1a3044] text-[10px] font-bold rounded-full hover:bg-[#1a3044] hover:text-white transition-all text-center uppercase tracking-widest">VER DETALHES</a>
        </div>

        <div class="flex flex-col bg-white rounded-xl shadow-sm border-t-[6px] border-t-orange-500 p-8">
          <h3 class="text-lg font-bold mb-4 font-heading text-[#1a3044]">Segurança do Trabalho</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow font-sans text-xs">
            {['PGR e LTCAT', 'Treinamentos NRs', 'Laudos'].map(i => (
              <li class="flex items-center text-slate-600"><span class="text-orange-600 mr-2 font-bold">✓</span> {i}</li>
            ))}
          </ul>
          <a href="/services#seguranca" class="py-2 border border-orange-500 text-orange-600 text-[10px] font-bold rounded-full hover:bg-orange-500 hover:text-white transition-all text-center uppercase tracking-widest">VER DETALHES</a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Pronto para crescer com segurança?"
    subtitle="Agende um diagnóstico com nossos especialistas."
    actions={[{ variant: 'primary', text: 'Agendar Conversa', href: '/contact', class: 'bg-orange-600 border-none px-6 py-2 rounded-full font-bold text-xs' }]}
  />

</Layout>

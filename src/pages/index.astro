---
import Layout from '~/layouts/Layout.astro'; // Mudamos para o Layout base direto
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança do Trabalho',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero
      actions={[
        { 
          variant: 'primary', 
          text: 'Agende uma conversa', 
          href: '/contact', 
          class: 'bg-orange-600 text-white px-6 py-2 rounded-full font-bold text-xs border-none' 
        },
        { 
          text: 'Nossos Serviços', 
          href: '#servicos-home', 
          class: 'border border-slate-300 text-[#1a3044] px-6 py-2 rounded-full font-bold text-xs' 
        },
      ]}
    >
      <Fragment slot="title">
        <div class="pt-2 md:pt-4 -mt-12 max-w-5xl mx-auto leading-[1.0] tracking-tighter text-[#1a3044] font-bold text-3xl md:text-5xl">
          <p class="text-[10px] md:text-xs text-[#3a8d44] font-bold uppercase tracking-[0.2em] mb-2">
            CONSULTORIA ESPECIALIZADA
          </p>
          <span class="block">Transformamos Exigências Legais</span>
          <span class="block">em Oportunidades de</span>
          <span class="text-[#3a8d44] block mt-[-4px]">Crescimento Sustentável</span>
          
          <p class="text-sm md:text-base text-slate-600 font-normal tracking-normal mt-4 leading-relaxed max-w-2xl mx-auto">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>
        </div>
      </Fragment>
    </Hero>

    </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* Menu Cinza Claro com Sombra - Aplicado aqui para ser 100% seguro */
  #header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 1px solid #e2e8f0 !important;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;
  }
  #header.header-custom a { color: #1a3044 !important; font-weight: 600; }
  #header.header-custom .btn-primary, #header.header-custom a[href*="contact"] {
    background-color: #ea580c !important; color: white !important;
    border-radius: 9999px !important; padding: 0.4rem 1.2rem !important;
  }
</style>

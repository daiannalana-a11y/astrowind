---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Engenharia e Consultoria',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero>
      <Fragment slot="title">
        <div class="pt-2 md:pt-4 -mt-14 max-w-5xl mx-auto tracking-tighter text-[#1a3044] font-bold text-3xl md:text-5xl text-center">
          <p class="text-[10px] md:text-xs text-[#3a8d44] font-bold uppercase tracking-[0.2em] mb-2 leading-none">
            DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA
          </p>
          <div class="leading-[0.95]">
            <span class="block">Transformamos Exigências Legais</span>
            <span class="block">em Oportunidades de</span>
            <span class="text-[#3a8d44] block">Crescimento Sustentável</span>
          </div>
          
          <p class="text-sm md:text-base text-slate-600 font-normal tracking-normal mt-6 leading-relaxed max-w-2xl mx-auto">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
            <a href="/contact" class="btn-triaxis-primary">
              Agende uma conversa
            </a>
            <a href="#servicos-home" class="btn-triaxis-secondary">
              Nossos Serviços
            </a>
          </div>
        </div>
      </Fragment>
    </Hero>

    <section class="py-12 md:py-16 bg-white border-t border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="mb-10 text-center max-w-3xl mx-auto">
          <p class="text-sm text-[#3a8d44] font-bold tracking-widest uppercase mb-2">Por que a Triaxis?</p>
          <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-4 text-[#1a3044]">Nossos Diferenciais</h2>
          <div class="w-20 h-1 bg-orange-500 mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="card-diferencial border-[#3a8d44]">
             <h3 class="font-bold text-[#1a3044]">Equilíbrio Técnica e Gestão</h3>
             <p class="text-sm text-slate-600 italic">Processos eficientes e pessoas equilibradas.</p>
          </div>
          <div class="card-diferencial border-[#1a3044]">
             <h3 class="font-bold text-[#1a3044]">Soluções Personalizadas</h3>
             <p class="text-sm text-slate-600 italic">Entendemos sua realidade e oferecemos planos sob medida.</p>
          </div>
          <div class="card-diferencial border-orange-500">
             <h3 class="font-bold text-[#1a3044]">Atuação Multidisciplinar</h3>
             <p class="text-sm text-slate-600 italic">Ambiental, Produção e Segurança integrada.</p>
          </div>
        </div>
      </div>
    </section>

    <Content
      isReversed
      image={{ src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80', alt: 'Equipe Triaxis' }}
    >
      <Fragment slot="content">
        <h3 class="text-orange-600 font-bold uppercase tracking-widest text-xs mb-3">CONHEÇA A TRIAXIS</h3>
        <h2 class="text-2xl md:text-3xl font-extrabold text-[#1a3044] mb-4">Resultados que surgem da integração.</h2>
        <p class="text-base text-slate-600 border-l-4 border-[#3a8d44] pl-4 mb-6">Unimos rigor normativo e visão estratégica para transformar conformidade legal em diferencial competitivo.</p>
        <a href="/about" class="bg-[#1a3044] text-white px-6 py-2.5 rounded-full font-bold text-sm">Saiba mais</a>
      </Fragment>
    </Content>

    <CallToAction
      title="Pronto para crescer?"
      subtitle="Agende um diagnóstico com nossos especialistas."
      actions={[{ variant: 'primary', text: 'Agendar Conversa', href: '/contact', class: 'bg-orange-600' }]}
    />
  </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* MENU COM SOMBRA E SEPARAÇÃO */
  header#header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 2px solid #e2e8f0 !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08) !important;
  }
  
  header#header.header-custom a { color: #1a3044 !important; font-weight: 600; text-decoration: none !important; }

  /* BOTÕES DO HERO */
  .btn-triaxis-primary {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    background-color: #ea580c !important; /* Laranja */
    color: white !important;
    padding: 0.8rem 2rem !important;
    border-radius: 9999px !important;
    font-weight: 700 !important;
    font-size: 0.875rem !important;
    text-decoration: none !important;
    min-width: 200px;
    line-height: 1.2 !important;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .btn-triaxis-secondary {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    border: 2px solid #e2e8f0 !important;
    color: #1a3044 !important;
    padding: 0.8rem 2rem !important;
    border-radius: 9999px !important;
    font-weight: 700 !important;
    font-size: 0.875rem !important;
    text-decoration: none !important;
    min-width: 200px;
    line-height: 1.2 !important;
  }

  /* CARDS DIFERENCIAIS */
  .card-diferencial {
    background-color: #f8fafc;
    padding: 2rem;
    border-radius: 24px;
    border-bottom: 4px solid;
    text-align: center;
    transition: transform 0.2s;
  }
  .card-diferencial:hover { transform: translateY(-5px); }
</style>

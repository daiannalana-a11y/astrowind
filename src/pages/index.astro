---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Engenharia e Consultoria',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero>
      <Fragment slot="title">
        <div class="pt-2 md:pt-4 -mt-14 max-w-5xl mx-auto leading-[0.95] tracking-tighter text-[#1a3044] font-bold text-3xl md:text-5xl text-center">
          <p class="text-[10px] md:text-xs text-[#3a8d44] font-bold uppercase tracking-[0.2em] mb-2">
            DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA
          </p>
          <span class="block">Transformamos Exigências Legais</span>
          <span class="block">em Oportunidades de</span>
          <span class="text-[#3a8d44] block">Crescimento Sustentável</span>
          
          <p class="text-sm md:text-base text-slate-600 font-normal tracking-normal mt-4 leading-relaxed max-w-2xl mx-auto">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>

          <div class="flex flex-row items-center justify-center gap-4 mt-8">
            <a href="/contact" class="bg-orange-600 hover:bg-orange-700 text-white px-7 py-2.5 rounded-full font-bold text-xs shadow-lg transition-all no-underline">
              Agende uma conversa
            </a>
            <a href="#servicos-home" class="border border-slate-300 hover:border-[#1a3044] text-[#1a3044] px-7 py-2.5 rounded-full font-bold text-xs transition-all no-underline">
              Nossos Serviços
            </a>
          </div>
        </div>
      </Fragment>
    </Hero>

    </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* Menu Cinza Claro com Sombra - Forçando via CSS global */
  #header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 1px solid #e2e8f0 !important;
    box-shadow: 0 4px 10px -1px rgba(0, 0, 0, 0.1) !important;
  }
  
  #header.header-custom a { 
    color: #1a3044 !important; 
    font-weight: 600; 
    text-decoration: none !important;
  }

  /* Botão do Menu (Fale Conosco) */
  #header.header-custom a[href*="contact"], 
  #header.header-custom .btn-primary {
    background-color: #1a3044 !important; /* Azul marinho no menu para elegância */
    color: white !important;
    border-radius: 9999px !important;
    padding: 0.5rem 1.5rem !important;
    font-size: 0.75rem !important;
    font-weight: 700 !important;
  }
</style>

---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Triaxis — Engenharia e Consultoria',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky class="header-custom" />

  <main>
    <Hero>
      <Fragment slot="title">
        <div class="triaxis-hero-scope">
          <p class="triaxis-tagline">DESENVOLVIMENTO, CONSULTORIA E ASSESSORIA ESPECIALIZADA</p>
          
          <h1 class="triaxis-title">
            Transformamos Exigências Legais<br/>
            em Oportunidades de<br/>
            <span class="triaxis-green">Crescimento Sustentável</span>
          </h1>
          
          <p class="triaxis-description">
            Consultoria Multidisciplinar Especializada em Engenharia Ambiental, 
            Engenharia de Produção e Segurança do Trabalho.
          </p>

          <div class="triaxis-button-group">
            <a href="/contact" class="tx-btn tx-btn-orange">
              Agende uma conversa
            </a>
            <a href="#servicos-home" class="tx-btn tx-btn-white">
              Nossos Serviços
            </a>
          </div>
        </div>
      </Fragment>
    </Hero>

    <section style="padding: 60px 0; background: white; text-align: center; border-top: 1px solid #eee;">
       <h2 style="color: #1a3044; font-weight: 800; font-size: 32px;">Nossos Diferenciais</h2>
       <p style="color: #3a8d44; font-weight: 700;">Excelência técnica em cada etapa</p>
    </section>

  </main>

  <Footer {...footerData} />
</Layout>

<style is:global>
  /* 1. CORREÇÃO DO MENU */
  header#header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 2px solid #e2e8f0 !important;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
  }
  header#header.header-custom a { color: #1a3044 !important; font-weight: 600; text-decoration: none; }

  /* 2. O "DESCOLADOR" DE LETRAS (TRI-AXIS SCOPE) */
  .triaxis-hero-scope { 
    margin-top: -60px; 
    text-align: center; 
    display: block !important;
  }

  .triaxis-tagline {
    color: #3a8d44 !important;
    font-weight: 800 !important;
    letter-spacing: 2px !important; /* Força espaço entre letras */
    font-size: 12px !important;
    margin-bottom: 20px !important;
  }

  .triaxis-title {
    color: #1a3044 !important;
    font-weight: 800 !important;
    font-size: 48px !important;
    line-height: 1.1 !important; /* Dá altura para a linha */
    letter-spacing: -0.5px !important; /* Evita que grude */
    margin-bottom: 25px !important;
  }

  .triaxis-green { color: #3a8d44 !important; }

  .triaxis-description {
    color: #64748b !important;
    font-size: 18px !important;
    line-height: 1.6 !important; /* Espaço entre linhas do subtítulo */
    letter-spacing: normal !important; /* Reseta o erro do tema */
    max-width: 750px !important;
    margin: 0 auto 40px auto !important;
  }

  /* 3. BOTÕES IMUNES AO TEMA */
  .triaxis-button-group {
    display: flex !important;
    flex-direction: row !important;
    justify-content: center !important;
    gap: 20px !important;
    padding-top: 10px !important;
  }

  .tx-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    height: 56px !important;
    padding: 0 35px !important;
    border-radius: 50px !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    text-decoration: none !important;
    letter-spacing: 0.5px !important; /* ESPAÇO ENTRE LETRAS DO BOTÃO */
    white-space: nowrap !important; /* Impede quebra de linha */
    transition: all 0.2s ease;
  }

  .tx-btn-orange {
    background-color: #ea580c !important;
    color: white !important;
    box-shadow: 0 10px 20px rgba(234, 88, 12, 0.3) !important;
  }

  .tx-btn-white {
    background-color: white !important;
    color: #1a3044 !important;
    border: 2px solid #e2e8f0 !important;
  }

  .tx-btn:hover { transform: translateY(-3px); }
</style>

---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança',
  description: 'Consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Consultoria Especializada"
    title="Transformamos exigências legais em oportunidades de crescimento sustentável"
    subtitle="Somos uma Consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho para empresas que precisam estar em conformidade e querem crescer de forma segura e eficiente."
    actions={[
      { variant: 'primary', text: 'Agende uma conversa', href: '/contact' },
      { text: 'Nossos Serviços', href: '#servicos-home' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Triaxis Consultoria' }}
  />

  <Features
    tagline="Por que a Triaxis?"
    title="Nossos Diferenciais"
    columns={3}
    items={[
      {
        title: 'Expertise Técnica',
        description: 'Equipe altamente qualificada com experiência sólida em consultoria ambiental, segurança e processos industriais.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Soluções Personalizadas',
        description: 'Abordagem sob medida para cada cliente, fugindo de relatórios de gaveta e garantindo resultados aplicáveis à rotina.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Visão Sustentável',
        description: 'Foco no equilíbrio entre eficiência operacional, desenvolvimento humano e conformidade socioambiental (ESG).',
        icon: 'tabler:world',
      },
    ]}
  />

  <section id="servicos-home" class="relative not-prose scroll-mt-[72px] py-12 md:py-20 bg-slate-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-10 md:mx-auto text-center max-w-3xl">
        <p class="text-base text-secondary font-semibold tracking-wide uppercase">Nossas Especialidades</p>
        <h2 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading text-heading">
          O que oferecemos para sua empresa
        </h2>
        <p class="max-w-3xl mx-auto text-xl text-muted dark:text-slate-400">
          Soluções integradas em engenharia para garantir conformidade legal e eficiência operacional.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        
        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-xl overflow-hidden border-t-8 border-green-600 transition-transform hover:scale-105">
          <div class="p-8 flex-grow">
            <h3 class="text-2xl font-bold text-center mb-6">Engenharia Ambiental</h3>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start">
                <span class="text-green-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Licenciamento Ambiental e Outorgas</span>
              </li>
              <li class="flex items-start">
                <span class="text-green-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Gestão de Resíduos (PGRS/PGRCC)</span>
              </li>
              <li class="flex items-start">
                <span class="text-green-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Recuperação de Áreas (PRAD)</span>
              </li>
              <li class="flex items-start">
                <span class="text-green-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Inventários de GEE e ESG</span>
              </li>
            </ul>
          </div>
          <div class="p-8 pt-0">
            <a href="/services#ambiental" class="flex justify-center py-3 px-6 border-2 border-green-600 text-green-600 font-bold rounded-lg hover:bg-green-600 hover:text-white transition-colors duration-300">
              Ver Detalhes
            </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-xl overflow-hidden border-t-8 border-blue-700 transition-transform hover:scale-105">
          <div class="p-8 flex-grow">
            <h3 class="text-2xl font-bold text-center mb-6">Engenharia de Produção</h3>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start">
                <span class="text-blue-700 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Diagnóstico Lean e Eficiência</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-700 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Mapeamento de Processos (VSM)</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-700 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Implementação 5S e Layout</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-700 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Gestão de Indicadores (KPIs)</span>
              </li>
            </ul>
          </div>
          <div class="p-8 pt-0">
            <a href="/services#producao" class="flex justify-center py-3 px-6 border-2 border-blue-700 text-blue-700 font-bold rounded-lg hover:bg-blue-700 hover:text-white transition-colors duration-300">
              Ver Detalhes
            </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-xl overflow-hidden border-t-8 border-orange-600 transition-transform hover:scale-105">
          <div class="p-8 flex-grow">
            <h3 class="text-2xl font-bold text-center mb-6">Segurança do Trabalho</h3>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start">
                <span class="text-orange-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Elaboração de PGR e LTCAT</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Treinamentos Normativos (NRs)</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Laudos de Insalubridade</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-3 mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">Gestão de EPIs e CIPA</span>
              </li>
            </ul>
          </div>
          <div class="p-8 pt-0">
            <a href="/services#seguranca" class="flex justify-center py-3 px-6 border-2 border-orange-600 text-orange-600 font-bold rounded-lg hover:bg-orange-600 hover:text-white transition-colors duration-300">
              Ver Detalhes
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Steps
    title="Como trabalhamos com a sua empresa"
    tagline="Nosso processo"
    items={[
      {
        title: '1. Diagnóstico',
        description: 'Realizamos um levantamento completo da situação atual da sua empresa em relação às exigências legais e oportunidades de melhoria.',
        icon: 'tabler:search',
      },
      {
        title: '2. Planejamento',
        description: 'Desenvolvemos um plano de ação personalizado com prazos, responsabilidades e metas claras para cada demanda identificada.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: '3. Execução',
        description: 'Nossa equipe técnica conduz as atividades com rigor, acompanhando cada etapa e garantindo qualidade nos resultados.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Resultado: sua empresa em conformidade e crescendo',
        icon: 'tabler:check',
      },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=987&q=80', alt: 'Equipe Triaxis em campo' }}
  />

  <Stats
    title="Triaxis em números"
    stats={[
      { title: 'Empresas atendidas', amount: '80+' },
      { title: 'Projetos entregues', amount: '200+' },
      { title: 'Anos de experiência', amount: '10+' },
      { title: 'Especialistas', amount: '5' },
    ]}
  />

  <FAQs
    title="Perguntas Frequentes"
    tagline="FAQ"
    subtitle="Tire suas dúvidas sobre os serviços da Triaxis."
    items={[
      {
        title: 'Quais tipos de empresa podem contratar a Triaxis?',
        description: 'Atendemos empresas de todos os portes e setores que precisam de conformidade ambiental, eficiência produtiva ou adequação às normas de segurança do trabalho.',
      },
      {
        title: 'Como funciona o licenciamento ambiental?',
        description: 'O licenciamento ambiental é um processo obrigatório para atividades que possam causar impacto ao meio ambiente. A Triaxis conduz todo o processo junto aos órgãos competentes, desde a documentação até a emissão das licenças.',
      },
      {
        title: 'O que são as NRs e por que minha empresa precisa segui-las?',
        description: 'As Normas Regulamentadoras (NRs) são obrigações legais do Ministério do Trabalho que definem as condições mínimas de segurança e saúde no trabalho. O não cumprimento pode gerar multas e interdições.',
      },
      {
        title: 'Como a consultoria de Produção pode reduzir meus custos?',
        description: 'Identificamos desperdícios, gargalos e ineficiências nos processos produtivos e aplicamos metodologias como Lean Manufacturing para aumentar a produtividade com os recursos que você já possui.',
      },
      {
        title: 'Como inicio um projeto com a Triaxis?',
        description: 'Basta entrar em contato pelo nosso formulário ou WhatsApp. Agendamos uma conversa inicial sem compromisso para entender sua necessidade e apresentar a melhor solução.',
      },
    ]}
  />

  <CallToAction
    title="Pronto para colocar sua empresa em conformidade?"
    subtitle="Entre em contato e descubra como a Triaxis pode transformar exigências legais em vantagem competitiva."
    actions={[
      { variant: 'primary', text: 'Fale com um especialista', href: '/contact' },
    ]}
  />

</Layout>

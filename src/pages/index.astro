---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança',
  description: 'Consultoria multidisciplinar para empresas que buscam conformidade legal e eficiência operacional.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Consultoria Especializada"
    title="Transformamos exigências legais em oportunidades de crescimento sustentável"
    subtitle="Somos uma consultoria multidisciplinar especializada em Meio Ambiente, Produção e Segurança do Trabalho para indústrias que buscam conformidade e crescimento eficiente."
    actions={[
      { variant: 'primary', text: 'Agende uma conversa', href: '/contact' },
      { text: 'Nossos Serviços', href: '#servicos-home' },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=2070&q=80', 
      alt: 'Triaxis Consultoria' 
    }}
  />

  <Features
    id="features"
    tagline="Diferenciais"
    title="Por que a Triaxis?"
    columns={3}
    items={[
      {
        title: 'Expertise Técnica',
        description: 'Equipe altamente qualificada com experiência sólida em consultoria ambiental e segurança.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Soluções Personalizadas',
        description: 'Abordagem sob medida para cada cliente, garantindo resultados aplicáveis à rotina.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Visão Sustentável',
        description: 'Foco no equilíbrio entre eficiência operacional e conformidade socioambiental (ESG).',
        icon: 'tabler:world',
      },
    ]}
    classes={{
      container: 'max-w-7xl mx-auto py-12 md:py-20',
      title: 'text-center text-3xl md:text-4xl font-bold tracking-tight mb-12 font-heading',
      items: {
        container: 'flex flex-col items-start text-left px-4', // Alinhado à esquerda conforme Imagem 1
        title: 'text-xl font-bold mt-4 mb-2',
        description: 'text-muted leading-relaxed text-sm',
        icon: 'w-12 h-12 text-blue-700 dark:text-blue-400', // Ícone apenas contorno (sem fundo circular)
      },
    }}
  />

  <Content
    id="quem-somos-home"
    isReversed
    tagline="Quem Somos"
    title="Muito além da teoria. Entregamos prática."
    image={{
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2071&q=80',
      alt: 'Equipe Triaxis trabalhando',
    }}
  >
    <Fragment slot="content">
      <p class="mb-4 text-muted dark:text-slate-400 text-lg leading-relaxed">
        A Triaxis nasceu da união de profissionais com experiência sólida e complementar em Engenharia Ambiental, Engenharia de Produção e Segurança do Trabalho.
      </p>
      <div class="flex flex-wrap gap-6 items-center mt-6">
        <a href="/contact" class="text-primary font-bold hover:underline flex items-center text-lg">
          Falar com nossa Equipe <span class="ml-2">→</span>
        </a>
      </div>
    </Fragment>
  </Content>

  <section id="servicos-home" class="bg-slate-50 dark:bg-slate-800 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold uppercase tracking-widest font-heading mb-12 text-gray-900 dark:text-white">
        Nossas Especialidades
      </h2>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-xl shadow-sm border-t-[6px] border-t-green-700 p-6">
          <h3 class="text-lg font-bold mb-4">Consultoria Ambiental</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow">
            {['Licenciamento Ambiental', 'Gestão de Resíduos', 'Outorgas'].map(i => (
              <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                <span class="text-green-700 mr-2 font-bold">✓</span> {i}
              </li>
            ))}
          </ul>
          <a href="/services#ambiental" class="block w-full py-2 border border-green-700 text-green-700 text-xs font-bold rounded hover:bg-green-700 hover:text-white transition-all text-center">VER DETALHES</a>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-xl shadow-sm border-t-[6px] border-t-blue-700 p-6">
          <h3 class="text-lg font-bold mb-4">Engenharia de Produção</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow">
            {['Diagnóstico Lean', 'Mapeamento VSM', 'Kpis e Layout'].map(i => (
              <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                <span class="text-blue-700 mr-2 font-bold">✓</span> {i}
              </li>
            ))}
          </ul>
          <a href="/services#producao" class="block w-full py-2 border border-blue-700 text-blue-700 text-xs font-bold rounded hover:bg-blue-700 hover:text-white transition-all text-center">VER DETALHES</a>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-xl shadow-sm border-t-[6px] border-t-orange-600 p-6">
          <h3 class="text-lg font-bold mb-4">Segurança do Trabalho</h3>
          <ul class="space-y-2 text-left mb-6 flex-grow">
            {['PGR e LTCAT', 'Treinamentos NRs', 'Laudos Técnicos'].map(i => (
              <li class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                <span class="text-orange-600 mr-2 font-bold">✓</span> {i}
              </li>
            ))}
          </ul>
          <a href="/services#seguranca" class="block w-full py-2 border border-orange-600 text-orange-600 text-xs font-bold rounded hover:bg-orange-600 hover:text-white transition-all text-center">VER DETALHES</a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    title="Pronto para colocar sua empresa em conformidade?"
    subtitle="Fale com nossa equipe técnica e receba um diagnóstico especializado."
    actions={[{ variant: 'primary', text: 'Agende uma conversa', href: '/contact' }]}
  />

</Layout>

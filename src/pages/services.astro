---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Serviços — Triaxis Consultoria',
  description: 'Conheça todos os serviços da Triaxis em Engenharia Ambiental, Engenharia de Produção e Segurança do Trabalho.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Nossos Serviços"
    title="Soluções técnicas completas para a sua empresa"
    subtitle="Atuamos nas três frentes que mais impactam a conformidade, a eficiência e a segurança das operações industriais e empresariais."
    actions={[
      { variant: 'primary', text: 'Fale com um especialista', href: getPermalink('/contact') },
    ]}
  />

  <Features
    id="ambiental"
    tagline="Engenharia Ambiental"
    title="Transformamos exigências legais em oportunidades"
    subtitle="Nossa equipe atua com foco em conformidade regulatória e melhoria contínua, ajudando sua empresa a atender às normas ambientais e fortalecer sua imagem institucional."
    columns={2}
    items={[
      {
        title: 'Assessoria Ambiental Contínua',
        description: 'Acompanhamento ambiental recorrente para manter sua empresa em conformidade ao longo do ano.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Diagnóstico de Conformidade Ambiental',
        description: 'Avaliação técnica da situação ambiental da empresa para identificar riscos e prioridades.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Licenciamento Ambiental',
        description: 'Conduzimos processos de licenciamento, regularização e renovação de licenças.',
        icon: 'tabler:license',
      },
      {
        title: 'Gerenciamento de Resíduos Sólidos (PGRS)',
        description: 'Elaboração e implantação do PGRS para organizar a rotina de resíduos e destinação.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Resíduos da Construção Civil (PGRCC)',
        description: 'Controle dos resíduos de obras, atendimento legal e organização documental.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Monitoramento e Relatórios Técnicos',
        description: 'Executamos monitoramentos e elaboramos relatórios técnicos para atender licenças.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Recuperação de Áreas Degradadas (PRAD/RAD)',
        description: 'Diagnóstico de campo e soluções técnicas para recuperação de áreas degradadas.',
        icon: 'tabler:trees',
      },
      {
        title: 'Inventário de GEE',
        description: 'Elaboração de inventários de emissões e planos de redução para demandas ESG.',
        icon: 'tabler:wind',
      },
    ]}
  />

  <CallToAction
    title="Quer ver o detalhamento ambiental?"
    subtitle="Clique abaixo para acessar o resumo de todos os serviços desta categoria."
    actions={[
      { variant: 'secondary', text: 'Ver Detalhes Ambientais', href: getPermalink('/servicos/ambiental') },
      { variant: 'primary', text: 'Falar com Especialista', href: getPermalink('/contact') },
    ]}
  />

  <Features
    id="producao"
    tagline="Engenharia de Produção"
    title="Transformamos processos desorganizados em operações eficientes"
    subtitle="Ajudamos sua empresa a eliminar desperdícios e aumentar a produtividade com metodologias modernas."
    columns={2}
    items={[
      {
        title: 'Diagnóstico Lean',
        description: 'Identificação de gargalos e oportunidades de melhoria na operação.',
        icon: 'tabler:search',
      },
      {
        title: 'Implementação 5S',
        description: 'Estruturação de organização, limpeza e disciplina no ambiente de trabalho.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Mapeamento VSM',
        description: 'Mapeamento do fluxo de valor para tornar os processos mais fluidos.',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Gestão de KPIs e OEE',
        description: 'Sistemas de indicadores para tomada de decisão baseada em dados.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Redesenho de Layout',
        description: 'Otimização de espaço e movimentação para uma produção equilibrada.',
        icon: 'tabler:layout',
      },
      {
        title: 'Gestão de Custos',
        description: 'Identificação de oportunidades de economia sem comprometer a qualidade.',
        icon: 'tabler:coin',
      },
      {
        title: 'Auditoria ISO',
        description: 'Adequação de processos aos padrões ISO 9001, 14001 e IATF 16949.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Treinamentos Lean',
        description: 'Capacitação de equipes voltada à autonomia e produtividade sustentável.',
        icon: 'tabler:school',
      },
    ]}
  />

  <CallToAction
    title="Foco em Eficiência e Lean?"
    subtitle="Conheça detalhadamente nossas metodologias de Engenharia de Produção."
    actions={[
      { variant: 'secondary', text: 'Ver Detalhes de Produção', href: getPermalink('/servicos/producao') },
      { variant: 'primary', text: 'Falar com Especialista', href: getPermalink('/contact') },
    ]}
  />

  <Features
    id="seguranca"
    tagline="Segurança do Trabalho"
    title="Transformamos riscos ocupacionais em ambientes mais seguros"
    subtitle="Identificação, controle e prevenção de riscos ocupacionais para conformidade com as NRs."
    columns={2}
    items={[
      {
        title: 'Diagnóstico de Segurança',
        description: 'Avaliação técnica das condições de trabalho e identificação de riscos.',
        icon: 'tabler:search',
      },
      {
        title: 'Gestão do PGR (NR-01)',
        description: 'Desenvolvimento e acompanhamento do Programa de Gerenciamento de Riscos.',
        icon: 'tabler:file-certificate',
      },
      {
        title: 'Laudos Técnicos',
        description: 'LTCAT, Insalubridade e Periculosidade com segurança jurídica.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Treinamentos NRs',
        description: 'Aplicação de treinamentos obrigatórios de forma prática e acessível.',
        icon: 'tabler:school',
      },
      {
        title: 'Gestão de EPIs',
        description: 'Avaliação de riscos e definição dos equipamentos adequados.',
        icon: 'tabler:shield',
      },
      {
        title: 'Análise Ergonômica (AET)',
        description: 'Prevenção de doenças ocupacionais e melhoria da produtividade.',
        icon: 'tabler:armchair',
      },
      {
        title: 'Auditoria de SST',
        description: 'Avaliação sistemática da conformidade com as normas vigentes.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Consultoria Contínua',
        description: 'Suporte técnico periódico e orientação para evolução do sistema SST.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <CallToAction
    title="Conformidade total com as NRs?"
    subtitle="Acesse o detalhamento técnico dos nossos laudos e treinamentos."
    actions={[
      { variant: 'secondary', text: 'Ver Detalhes de Segurança', href: getPermalink('/servicos/seguranca') },
      { variant: 'primary', text: 'Falar com Especialista', href: getPermalink('/contact') },
    ]}
  />

</Layout>

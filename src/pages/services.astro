---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = { title: 'Serviços — Triaxis Consultoria' };
---

<Layout metadata={metadata}>
  <Hero
    tagline="Nossas Soluções"
    title="Engenharia integrada para resultados sustentáveis"
    subtitle="Confira nosso portfólio completo de serviços em Meio Ambiente, Produção e Segurança do Trabalho."
  />

  <Features2
    id="ambiental"
    title="Engenharia Ambiental"
    subtitle="Conformidade legal e gestão estratégica de recursos naturais."
    items={[
      { title: 'Licenciamento Ambiental', description: 'LP, LI e LO para diversos setores industriais.', icon: 'tabler:file-certificate' },
      { title: 'Gestão de Resíduos', description: 'PGRS, PGRCC e implementação de logística reversa.', icon: 'tabler:trash' },
      { title: 'Inventário de GEE', description: 'Cálculo de emissões e estratégias de descarbonização.', icon: 'tabler:cloud-fog' },
      { title: 'Assessoria Contínua', description: 'Monitoramento mensal de condicionantes e obrigações.', icon: 'tabler:calendar-check' },
    ]}
    classes={{ 
        container: 'bg-green-50/30 dark:bg-slate-900',
        items: { icon: 'text-green-700 bg-green-100 rounded-full p-2' } 
    }}
  />

  <Features2
    id="producao"
    title="Engenharia de Produção"
    subtitle="Otimização de processos para aumentar a lucratividade."
    items={[
      { title: 'Diagnóstico Lean', description: 'Identificação de desperdícios e oportunidades de melhoria.', icon: 'tabler:chart-line' },
      { title: 'Mapeamento VSM', description: 'Visualização completa do fluxo de valor e gargalos.', icon: 'tabler:map-2' },
      { title: 'Layout Industrial', description: 'Otimização do espaço físico e fluxo de materiais.', icon: 'tabler:arrows-maximize' },
      { title: 'Gestão de KPIs', description: 'Criação de indicadores de performance em tempo real.', icon: 'tabler:dashboard' },
    ]}
    classes={{ 
        container: 'bg-white dark:bg-slate-800',
        items: { icon: 'text-blue-700 bg-blue-100 rounded-full p-2' } 
    }}
  />

  <Features2
    id="seguranca"
    title="Segurança do Trabalho"
    subtitle="Proteção do capital humano e redução de passivos trabalhistas."
    items={[
      { title: 'PGR e LTCAT', description: 'Documentações fundamentais para o eSocial.', icon: 'tabler:shield-lock' },
      { title: 'Treinamentos NRs', description: 'Capacitações obrigatórias (NR-10, 12, 35, etc).', icon: 'tabler:users' },
      { title: 'Laudos Técnicos', description: 'Insalubridade e Periculosidade com rigor técnico.', icon: 'tabler:report-analytics' },
      { title: 'Gestão de EPIs', description: 'Controle de entrega e validade de equipamentos.', icon: 'tabler:user-check' },
    ]}
    classes={{ 
        container: 'bg-orange-50/30 dark:bg-slate-900',
        items: { icon: 'text-orange-600 bg-orange-100 rounded-full p-2' } 
    }}
  />

  <CallToAction
    title="Precisa de uma solução específica?"
    subtitle="Nossa equipe está pronta para desenhar um projeto sob medida para sua empresa."
    actions={[{ variant: 'primary', text: 'Solicitar Orçamento', href: '/contact' }]}
  />
</Layout>

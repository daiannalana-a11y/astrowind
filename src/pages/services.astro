---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Triaxis — Consultoria em Engenharia Ambiental, Produção e Segurança',
  description: 'Consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho para empresas que buscam conformidade e crescimento.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Consultoria Especializada"
    title="Transformamos exigências legais em oportunidades de crescimento sustentável"
    subtitle="Somos uma consultoria especializada em Meio Ambiente, Produção e Segurança do Trabalho para empresas que precisam estar em conformidade e querem crescer de forma segura e eficiente."
    actions={[
      { variant: 'primary', text: 'Agende uma conversa', href: '/contact' },
      { text: 'Nossos Serviços', href: '#servicos-home' },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=2070&q=80', 
      alt: 'Triaxis Consultoria Escritório' 
    }}
  />

  <Features
    id="features"
    tagline="Por que a Triaxis?"
    title="Nossos Diferenciais"
    columns={3}
    classes={{
      container: 'max-w-7xl mx-auto py-16 md:py-24',
      title: 'text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center',
      items: {
        container: 'relative flex flex-row items-start p-4', // Força o ícone ao lado
        title: 'text-xl font-bold ml-4 text-gray-900 dark:text-white',
        description: 'text-muted mt-2 ml-4 leading-relaxed text-sm',
        icon: 'flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-slate-800 dark:bg-slate-700 text-white p-3 shadow-md', // Ícone escuro e redondo
      },
    }}
    items={[
      {
        title: 'Expertise Técnica',
        description: 'Equipe altamente qualificada com experiência sólida em consultoria ambiental, segurança e processos industriais.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Soluções Personalizadas',
        description: 'Abordagem sob medida para cada cliente, fugindo de relatórios de gaveta e garantindo resultados aplicáveis.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Visão Sustentável',
        description: 'Foco no equilíbrio entre eficiência operacional, desenvolvimento humano e conformidade socioambiental (ESG).',
        icon: 'tabler:world',
      },
    ]}
  />

  <section id="servicos-home" class="bg-slate-50 dark:bg-slate-800 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white uppercase font-heading">
          Nossas Especialidades
        </h2>
        <p class="max-w-3xl mx-auto mt-4 text-xl text-muted">Soluções integradas em engenharia para sua empresa.</p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        
        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-green-700 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow">
            <h3 class="text-xl font-bold text-center mb-5 text-gray-800 dark:text-white leading-tight">Consultoria Ambiental</h3>
            <div class="w-12 h-px bg-gray-100 mx-auto mb-6"></div>
            <ul class="space-y-3 mb-6">
              {[
                'Licenciamento Ambiental e Outorgas',
                'Gestão de Resíduos (PGRS/PGRCC)',
                'Recuperação de Áreas (PRAD)',
                'Inventários de GEE e ESG'
              ].map((item) => (
                <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-green-700 mr-2 font-bold text-lg">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0 text-center">
            <a href="/services#ambiental" class="inline-block w-full py-2.5 px-4 border border-green-700 text-green-700 text-sm font-bold rounded-md hover:bg-green-700 hover:text-white transition-all">
              Ver Detalhes
            </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-blue-700 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow">
            <h3 class="text-xl font-bold text-center mb-5 text-gray-800 dark:text-white leading-tight">Engenharia de Produção</h3>
            <div class="w-12 h-px bg-gray-100 mx-auto mb-6"></div>
            <ul class="space-y-3 mb-6">
              {[
                'Diagnóstico Lean e Eficiência',
                'Mapeamento de Processos (VSM)',
                'Implementação 5S e Layout',
                'Gestão de Indicadores (KPIs)'
              ].map((item) => (
                <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-blue-700 mr-2 font-bold text-lg">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0 text-center">
            <a href="/services#producao" class="inline-block w-full py-2.5 px-4 border border-blue-700 text-blue-700 text-sm font-bold rounded-md hover:bg-blue-700 hover:text-white transition-all">
              Ver Detalhes
            </a>
          </div>
        </div>

        <div class="flex flex-col bg-white dark:bg-slate-900 rounded-lg shadow-md border border-gray-100 dark:border-slate-700 border-t-[6px] border-t-orange-600 transition-all hover:shadow-lg">
          <div class="p-6 flex-grow">
            <h3 class="text-xl font-bold text-center mb-5 text-gray-800 dark:text-white leading-tight">Segurança do Trabalho</h3>
            <div class="w-12 h-px bg-gray-100 mx-auto mb-6"></div>
            <ul class="space-y-3 mb-6">
              {[
                'Elaboração de PGR e LTCAT',
                'Treinamentos Normativos (NRs)',
                'Laudos de Insalubridade',
                'Gestão de EPIs e CIPA'
              ].map((item) => (
                <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                  <span class="text-orange-600 mr-2 font-bold text-lg">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-6 pt-0 text-center">
            <a href="/services#seguranca" class="inline-block w-full py-2.5 px-4 border border-orange-600 text-orange-600 text-sm font-bold rounded-md hover:bg-orange-600 hover:text-white transition-all">
              Ver Detalhes
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Steps
    title="Como trabalhamos com a sua empresa"
    tagline="Nosso processo"
    classes={{
      container: 'max-w-4xl mx-auto py-16 md:py-24',
      title: 'text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center',
    }}
    items={[
      { title: '1. Diagnóstico', description: 'Levantamento completo da situação atual.', icon: 'tabler:search' },
      { title: '2. Planejamento', description: 'Plano de ação personalizado com metas.', icon: 'tabler:clipboard-list' },
      { title: '3. Execução', description: 'Equipe técnica conduz as atividades com rigor.', icon: 'tabler:rocket' },
      { title: 'Resultado: Conformidade', icon: 'tabler:check' },
    ]}
  />

  <CallToAction
    title="Pronto para colocar sua empresa em conformidade?"
    subtitle="Entre em contato e descubra como a Triaxis pode transformar exigências legais em vantagem competitiva."
    actions={[{ variant: 'primary', text: 'Fale com um especialista', href: '/contact' }]}
  />

</Layout>

---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Serviços — Triaxis Consultoria',
  description: 'Conheça todos os serviços da Triaxis em Engenharia Ambiental, Engenharia de Produção e Segurança do Trabalho.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Nossos Serviços"
    title="Soluções técnicas completas para a sua empresa"
    subtitle="Atuamos nas três frentes que mais impactam a conformidade, a eficiência e a segurança das operações industriais e empresariais."
    actions={[
      { variant: 'primary', text: 'Fale com um especialista', href: getPermalink('/contact') },
    ]}
  />

  <Features
    id="ambiental"
    tagline="Engenharia Ambiental"
    title="Transformamos exigências legais em oportunidades"
    subtitle="Clique em 'Saiba mais' em cada item para ver o detalhamento técnico de cada solução ambiental."
    columns={2}
    items={[
      {
        title: 'Assessoria Ambiental Contínua',
        description: 'Acompanhamento recorrente para manter sua empresa em conformidade. <br/><a href="/servicos/ambiental/assessoria-continua" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Diagnóstico de Conformidade Ambiental',
        description: 'Avaliação técnica para identificar riscos e prioridades. <br/><a href="/servicos/ambiental/diagnostico-conformidade" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Licenciamento Ambiental',
        description: 'Processos de licenciamento e regularização documental. <br/><a href="/servicos/ambiental/licenciamento" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:license',
      },
      {
        title: 'Gerenciamento de Resíduos (PGRS)',
        description: 'Elaboração e implantação do PGRS para rotina de resíduos. <br/><a href="/servicos/ambiental/pgrs" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:recycle',
      },
      {
        title: 'Resíduos da Construção Civil (PGRCC)',
        description: 'Controle de resíduos em obras e atendimento às exigências. <br/><a href="/servicos/ambiental/pgrcc" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Monitoramento e Relatórios Técnicos',
        description: 'Executamos monitoramentos e elaboramos relatórios confiáveis. <br/><a href="/servicos/ambiental/monitoramento" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Recuperação de Áreas Degradadas (PRAD/RAD)',
        description: 'Soluções técnicas para recuperação de áreas e licenciamento. <br/><a href="/servicos/ambiental/prad" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:trees',
      },
      {
        title: 'Emissões e Mudanças Climáticas (GEE)',
        description: 'Inventários de emissões e planos de redução para demandas ESG. <br/><a href="/servicos/ambiental/gee" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:wind',
      },
    ]}
  />

  <Features
    id="producao"
    tagline="Engenharia de Produção"
    title="Transformamos processos desorganizados em operações eficientes"
    subtitle="Clique em 'Saiba mais' para entender nossas metodologias de ganho de produtividade."
    columns={2}
    items={[
      {
        title: 'Diagnóstico Lean',
        description: 'Identificação de gargalos e oportunidades de melhoria. <br/><a href="/servicos/producao/diagnostico-lean" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:search',
      },
      {
        title: 'Implementação 5S',
        description: 'Estruturação de organização, limpeza e disciplina. <br/><a href="/servicos/producao/5s" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Mapeamento de Processos (VSM)',
        description: 'Mapeamento do fluxo de valor para eliminar desperdícios. <br/><a href="/servicos/producao/vsm" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Gestão de Indicadores (KPIs)',
        description: 'Sistemas de gestão para tomada de decisão baseada em dados. <br/><a href="/servicos/producao/kpis" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Redesenho de Layout',
        description: 'Otimização de espaço e movimentação produtiva. <br/><a href="/servicos/producao/layout" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:layout',
      },
      {
        title: 'Gestão de Custos',
        description: 'Identificação de oportunidades reais de economia. <br/><a href="/servicos/producao/gestao-custos" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:coin',
      },
      {
        title: 'Auditoria e Qualidade (ISO)',
        description: 'Adequação de processos aos padrões ISO e certificações. <br/><a href="/servicos/producao/qualidade" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:certificate',
      },
      {
        title: 'Treinamentos Lean',
        description: 'Capacitação de equipes para autonomia e produtividade. <br/><a href="/servicos/producao/treinamentos-lean" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:school',
      },
    ]}
  />

  <Features
    id="seguranca"
    tagline="Segurança do Trabalho"
    title="Transformamos riscos ocupacionais em ambientes mais seguros"
    subtitle="Clique em 'Saiba mais' para ver os detalhes de conformidade e proteção."
    columns={2}
    items={[
      {
        title: 'Diagnóstico de Segurança',
        description: 'Avaliação técnica das condições e identificação de riscos. <br/><a href="/servicos/seguranca/diagnostico" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:search',
      },
      {
        title: 'Elaboração do PGR (NR-01)',
        description: 'Desenvolvimento e acompanhamento do Programa de Riscos. <br/><a href="/servicos/seguranca/pgr" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:file-certificate',
      },
      {
        title: 'Laudos Técnicos (LTCAT)',
        description: 'Análises para segurança jurídica, previdenciária e trabalhista. <br/><a href="/servicos/seguranca/laudos" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:file-description',
      },
      {
        title: 'Treinamentos Normativos (NRs)',
        description: 'Capacitação obrigatória de forma prática e acessível. <br/><a href="/servicos/seguranca/treinamentos" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:school',
      },
      {
        title: 'Gestão de EPIs',
        description: 'Definição, fichas e acompanhamento da correta utilização. <br/><a href="/servicos/seguranca/epis" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:shield',
      },
      {
        title: 'Análise Ergonômica (AET)',
        description: 'Prevenção de doenças e melhoria do bem-estar ocupacional. <br/><a href="/servicos/seguranca/ergonomia" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:armchair',
      },
      {
        title: 'Auditoria de Segurança',
        description: 'Avaliação da conformidade real com os requisitos legais. <br/><a href="/servicos/seguranca/auditoria" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Consultoria SST Contínua',
        description: 'Acompanhamento periódico e suporte em fiscalizações. <br/><a href="/servicos/seguranca/consultoria" class="text-primary font-semibold hover:underline">Saiba mais →</a>',
        icon: 'tabler:headset',
      },
    ]}
  />

  <CallToAction
    title="Sua empresa precisa de uma solução técnica específica?"
    subtitle="Fale diretamente com um de nossos engenheiros e tire suas dúvidas agora mesmo."
    actions={[
      { variant: 'primary', text: 'Entrar em Contato', href: getPermalink('/contact') },
    ]}
  />

</Layout>

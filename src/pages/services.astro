---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Serviços — Triaxis Consultoria',
  description: 'Conheça todos os serviços da Triaxis em Engenharia Ambiental, Engenharia de Produção e Segurança do Trabalho.',
};
---

<Layout metadata={metadata}>

  <Hero
    tagline="Nossos Serviços"
    title="Soluções técnicas completas para a sua empresa"
    subtitle="Atuamos nas três frentes que mais impactam a conformidade, a eficiência e a segurança das operações industriais e empresariais."
    actions={[
      { variant: 'primary', text: 'Fale com um especialista', href: '/contact' },
    ]}
  />

  <!-- ENGENHARIA AMBIENTAL -->
  <Features
    id="ambiental"
    tagline="Engenharia Ambiental"
    title="Transformamos exigências legais em oportunidades"
    subtitle="Nossa equipe atua com foco em conformidade regulatória e melhoria contínua, ajudando sua empresa a atender às normas ambientais e fortalecer sua imagem institucional."
    columns={2}
    items={[
      {
        title: 'Assessoria Ambiental Contínua',
        description: 'Acompanhamento ambiental recorrente para manter sua empresa em conformidade ao longo do ano, com controle de prazos, licenças, condicionantes e resíduos, evitando multas e surpresas de última hora.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Diagnóstico de Conformidade Ambiental',
        description: 'Avaliação técnica da situação ambiental da empresa para identificar riscos, não conformidades e prioridades, com plano de ação claro e aplicável para regularizar com previsibilidade.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Licenciamento Ambiental',
        description: 'Conduzimos processos de licenciamento, regularização e renovação de licenças ambientais, com organização documental e suporte técnico junto aos órgãos competentes.',
        icon: 'tabler:license',
      },
      {
        title: 'Gerenciamento de Resíduos Sólidos (PGRS)',
        description: 'Elaboração e implantação do PGRS para organizar a rotina de resíduos, desde a segregação até a destinação, com registros e evidências prontas para fiscalização e auditoria.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Resíduos da Construção Civil (PGRCC)',
        description: 'Desenvolvemos o PGRCC para obras e atividades da construção civil, garantindo controle dos resíduos, atendimento às exigências legais e organização documental para órgãos e contratantes.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Monitoramento e Relatórios Técnicos Ambientais',
        description: 'Executamos monitoramentos ambientais e elaboramos relatórios técnicos confiáveis para atender licenças, condicionantes, auditorias e fiscalizações, com dados organizados e prazos controlados.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Recuperação de Áreas Degradadas (PRAD/RAD)',
        description: 'Elaboramos PRAD/RAD com diagnóstico de campo, soluções técnicas e cronograma executável para recuperação de áreas degradadas, atendendo exigências de licenciamento e mineração.',
        icon: 'tabler:trees',
      },
      {
        title: 'Emissões e Mudanças Climáticas (Inventário de GEE)',
        description: 'Elaboração de inventários de emissões de GEE e planos de redução, com dados rastreáveis e ações realistas para atender demandas ESG, auditorias e exigências de clientes e contratantes.',
        icon: 'tabler:wind',
      },
    ]}
  />

  <CallToAction
    title="Precisa de apoio ambiental?"
    subtitle="Entre em contato e veja como podemos regularizar e proteger sua empresa."
    actions={[
      { variant: 'primary', text: 'Falar com especialista ambiental', href: '/contact' },
    ]}
  />

  <!-- ENGENHARIA DE PRODUÇÃO -->
  <Features
    id="producao"
    tagline="Engenharia de Produção"
    title="Transformamos processos desorganizados em operações eficientes"
    subtitle="Ajudamos sua empresa a identificar gargalos, eliminar desperdícios e aumentar a produtividade com metodologias modernas e aplicáveis à sua realidade."
    columns={2}
    items={[
      {
        title: 'Diagnóstico Lean e Plano de Melhoria Contínua',
        description: 'Realizamos o diagnóstico da operação identificando gargalos, desperdícios e oportunidades de melhoria, estruturando um plano de ação para aumentar a eficiência e a previsibilidade dos processos.',
        icon: 'tabler:search',
      },
      {
        title: 'Implementação 5S e Padronização Operacional',
        description: 'Implantamos o programa 5S estruturando organização, limpeza e disciplina para transformar o ambiente de trabalho, reduzir desperdícios e elevar o padrão de qualidade da operação.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Mapeamento de Processos e Eliminação de Desperdícios (VSM)',
        description: 'Realizamos o mapeamento dos processos e do fluxo de valor, identificando perdas e ineficiências ao longo da operação para tornar os processos mais fluidos e eficientes.',
        icon: 'tabler:git-branch',
      },
      {
        title: 'Gestão de Indicadores e Performance (KPIs e OEE)',
        description: 'Estruturamos sistemas de gestão por indicadores, transformando dados operacionais em informações claras para tomada de decisão e melhoria contínua da performance.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Redesenho de Layout e Balanceamento de Produção',
        description: 'Realizamos estudos técnicos para reorganizar o fluxo produtivo, otimizando espaço, movimentação e ritmo de trabalho para uma produção mais fluida, segura e equilibrada.',
        icon: 'tabler:layout',
      },
      {
        title: 'Gestão de Custos e Eficiência de Recursos',
        description: 'Analisamos os custos da operação identificando onde os recursos são consumidos e onde existem oportunidades de economia e ganho de eficiência sem comprometer qualidade ou prazo.',
        icon: 'tabler:coin',
      },
      {
        title: 'Auditoria e Certificação da Qualidade (ISO, FMEA, 8D)',
        description: 'Avaliamos e estruturamos sistemas de qualidade para adequar processos aos padrões ISO 9001, ISO 14001 e IATF 16949, criando um sistema sólido e aplicável à rotina real da operação.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Treinamentos em Lean Manufacturing',
        description: 'Desenvolvemos e aplicamos programas de capacitação voltados à formação de equipes mais autônomas, produtivas e alinhadas à filosofia Lean, com foco em ganhos reais e sustentáveis.',
        icon: 'tabler:school',
      },
    ]}
  />

  <CallToAction
    title="Quer aumentar a eficiência da sua operação?"
    subtitle="Converse com nosso time de Engenharia de Produção e descubra onde estão seus maiores ganhos."
    actions={[
      { variant: 'primary', text: 'Falar com especialista em produção', href: '/contact' },
    ]}
  />

  <!-- SEGURANÇA DO TRABALHO -->
  <Features
    id="seguranca"
    tagline="Segurança do Trabalho"
    title="Transformamos riscos ocupacionais em ambientes mais seguros"
    subtitle="Atuamos com foco na identificação, controle e prevenção de riscos ocupacionais, ajudando sua empresa a atender às exigências legais de SST e reduzir acidentes."
    columns={2}
    items={[
      {
        title: 'Diagnóstico de Segurança do Trabalho',
        description: 'Avaliação técnica das condições de trabalho com identificação de riscos físicos, químicos, biológicos, ergonômicos e de acidentes, servindo como base para adequação legal e decisões estratégicas.',
        icon: 'tabler:search',
      },
      {
        title: 'Elaboração e Gestão do PGR (NR-01)',
        description: 'Desenvolvimento e acompanhamento do PGR conforme a NR-01, incluindo inventário de riscos, avaliação de perigos, definição de medidas de controle e monitoramento das ações.',
        icon: 'tabler:file-certificate',
      },
      {
        title: 'Laudos Técnicos (LTCAT, Insalubridade e Periculosidade)',
        description: 'Elaboração de laudos técnicos com análises criteriosas e fundamentadas, subsidiando decisões legais, previdenciárias e trabalhistas com segurança jurídica para a empresa.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Treinamentos Normativos (NRs)',
        description: 'Planejamento e aplicação de treinamentos obrigatórios conforme NR-01, NR-05, NR-06, NR-10, NR-12, NR-17, NR-23, NR-33, NR-35 e outras, de forma prática e acessível.',
        icon: 'tabler:school',
      },
      {
        title: 'Implantação e Gestão do Uso de EPIs',
        description: 'Avaliação dos riscos, definição dos EPIs adequados, elaboração de fichas de entrega e acompanhamento da correta utilização, contribuindo para redução de acidentes e afastamentos.',
        icon: 'tabler:shield',
      },
      {
        title: 'Análise Ergonômica do Trabalho (AET)',
        description: 'Avaliação das condições ergonômicas dos postos de trabalho com foco na prevenção de doenças ocupacionais, propondo melhorias práticas que promovem saúde e aumentam produtividade.',
        icon: 'tabler:armchair',
      },
      {
        title: 'Auditoria de Segurança do Trabalho',
        description: 'Avaliação sistemática da conformidade com as NRs e requisitos legais, analisando documentos, práticas e condições reais de trabalho, identificando falhas e oportunidades de melhoria.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Consultoria Contínua em Segurança do Trabalho',
        description: 'Acompanhamento técnico periódico com suporte, atualização normativa, apoio em fiscalizações, monitoramento de indicadores e orientação à gestão para evolução contínua do sistema de SST.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <CallToAction
    title="Sua empresa está em conformidade com as NRs?"
    subtitle="Fale com nosso time de Segurança do Trabalho e proteja seus colaboradores e sua empresa."
    actions={[
      { variant: 'primary', text: 'Falar com especialista em segurança', href: '/contact' },
    ]}
  />

</Layout>

---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header {...headerData} isSticky class="header-custom" />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>

<style is:global>
  /* CONFIGURAÇÃO DO MENU CINZA CLARO COM SOMBRA */
  #header.header-custom {
    background-color: #f8fafc !important;
    border-bottom: 1px solid #e2e8f0 !important;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;
  }

  #header.header-custom a {
    color: #1a3044 !important;
    font-weight: 600;
  }

  /* BOTÃO FALE CONOSCO NO MENU */
  #header.header-custom a[href*="contact"], 
  #header.header-custom .btn-primary {
    background-color: #ea580c !important;
    color: white !important;
    border: none !important;
    border-radius: 9999px !important;
    padding: 0.4rem 1.2rem !important;
    font-size: 0.8rem !important;
    font-weight: 700 !important;
  }
</style>
